# Supabase Security Config
# 此為環境變數範本檔，請複製此檔案並重新命名為 .env，然後填入您的金鑰。

# 您的 secret_key (新版的 service_key，具備最高權限，用於後端腳本)
# 請將下方的值替換成您在 Supabase 後台複製的新私鑰
SUPABASE_SERVICE_KEY=your_supabase_secret_key_here
SUPABASE_URL=your_supabase_project_url_here

# 您的 publishable_key (新版的 anon_key，用於前端瀏覽器)
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# FinMind API Token (用於抓取最新股價)
FINMIND_TOKEN=your_finmind_api_token_here
